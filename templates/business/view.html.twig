{% extends 'base.html.twig' %}

{% block title %}{{ business.name }} | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Business profile</p>
            <h1 class="page-title">{{ business.name }}</h1>
            <p class="page-subtitle">{{ business.city }}, {{ business.street }} {{ business.houseNumber }}</p>
        </div>

        <div class="toolbar">
            {% if is_granted('ROLE_BUSINESS') %}
                <a class="btn btn-primary" href="{{ path('app_package_new', { id: business.id }) }}">Add package</a>
            {% endif %}
            <a class="btn btn-ghost" href="{{ path('app_business') }}">Back to list</a>
        </div>
    </section>

    <section class="detail-grid">
        <article class="card detail-card detail-card--wide">
            <p class="eyebrow">Details</p>
            <dl class="info-list">
                <div>
                    <dt>ID</dt>
                    <dd>{{ business.id }}</dd>
                </div>
                <div>
                    <dt>City</dt>
                    <dd>{{ business.city }}</dd>
                </div>
                <div>
                    <dt>Street</dt>
                    <dd>{{ business.street }}</dd>
                </div>
                <div>
                    <dt>House number</dt>
                    <dd>{{ business.houseNumber }}</dd>
                </div>
                <div>
                    <dt>Phone number</dt>
                    <dd>{{ business.phoneNumber }}</dd>
                </div>
                <div>
                    <dt>Business type</dt>
                    <dd>{{ business.businessType ? business.businessType.name : '—' }}</dd>
                </div>
            </dl>
        </article>

        <article class="card detail-card detail-card--narrow">
            <p class="eyebrow">Packages</p>
            <p class="stat">{{ packages|length }}</p>
            <p class="muted">Packages linked to this business.</p>
        </article>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <strong>Packages</strong>
                <span class="muted">managed by this business</span>
            </div>
        </div>

        {{ include('table.html.twig', { packages: packages }) }}
    </section>
{% endblock %}
