{% extends 'base.html.twig' %}

{% block title %}Business Orders | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Orders</p>
            <h1 class="page-title">Business orders</h1>
            <p class="page-subtitle">Manage orders placed for your packages.</p>
        </div>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <strong>{{ orders|length }}</strong>
                <span class="muted">orders to manage</span>
            </div>
        </div>

        <div class="table-shell">
            <table class="data-table">
                <thead>
                <tr>
                    <th>Order</th>
                    <th>Package</th>
                    <th>Customer</th>
                    <th>Price</th>
                    <th>Status</th>
                    <th>Created at</th>
                    <th>Actions</th>
                </tr>
                </thead>
                <tbody>
                {% for order in orders %}
                    <tr>
                        <td>#{{ order.id }}</td>
                        <td>{{ order.package ? order.package.description : '—' }}</td>
                        <td>{{ order.consumer ? order.consumer.firstName ~ ' ' ~ order.consumer.lastName : '—' }}</td>
                        <td>{{ order.package ? order.package.price|number_format(2, '.', ',') : '—' }}</td>
                        <td><span class="badge badge--{{ order.status }}">{{ order.status|capitalize }}</span></td>
                        <td>{{ order.createdAt ? order.createdAt|date('Y-m-d H:i') : '—' }}</td>
                        <td class="table-actions">
                            <a class="btn btn-ghost btn-sm" href="{{ path('app_order_view', { id: order.id }) }}">View</a>
                            {% if order.status == 'placed' %}
                                <form method="post" action="{{ path('app_order_complete', { id: order.id }) }}" style="display:inline" onsubmit="return confirm('Mark this order as picked up?');">
                                    <button class="btn btn-primary btn-sm" type="submit">Mark as picked up</button>
                                </form>
                            {% endif %}
                        </td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="7">
                            <div class="empty-state">No orders for your packages yet.</div>
                        </td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </section>
{% endblock %}
