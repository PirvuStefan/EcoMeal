{% extends 'base.html.twig' %}

{% block title %}New Package | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Package form</p>
            <h1 class="page-title">Create package</h1>
            <p class="page-subtitle">Add a new package and keep the catalog organized.</p>
        </div>
    </section>

    <section class="form-card">
        {{ form_start(form, {'attr': {'class': 'app-form'}}) }}
        <div class="form-grid">
            {{ form_row(form.description) }}
            {{ form_row(form.price) }}
            {{ form_row(form.photo) }}
            {{ form_row(form.category) }}
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Create package</button>
            <a class="btn btn-ghost" href="{{ path('app_business') }}">Back to businesses</a>
        </div>
        {{ form_end(form) }}
    </section>

{% endblock %}
