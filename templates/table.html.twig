<div class="table-shell">
    <table class="data-table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Package</th>
            <th>Price</th>
            <th>Photo</th>
            <th>Created at</th>
            <th>Category</th>
            <th>Business</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for package in packages %}
            {% set isMysteryBox = package.isMysteryBox|default(false) %}
            <tr class="{{ isMysteryBox ? 'package-row package-row--mystery' : '' }}">
                <td>
                    <div class="package-name">
                        <span>{{ package.name ? package.name : '—' }}</span>
                        {% if isMysteryBox %}
                            <span class="badge badge--mystery">Highlighted</span>
                        {% endif %}
                    </div>
                </td>
                <td>
                    {% if isMysteryBox %}
                        <span class="table-link">{{ package.description }}</span>
                    {% else %}
                        <a class="table-link" href="{{ path('app_package_view', { id: package.id }) }}">
                            {{ package.description }}
                        </a>
                    {% endif %}
                    <div class="table-meta">
                        {% if isMysteryBox %}
                            Calculated from business average
                        {% else %}
                            ID {{ package.id }}
                        {% endif %}
                    </div>
                </td>
                <td>
                    <span class="{{ isMysteryBox ? 'package-price package-price--mystery' : 'package-price' }}">
                        {{ package.price|number_format(2, '.', ',') }}
                    </span>
                </td>
                <td>{{ package.photo ? package.photo : '—' }}</td>
                <td>{{ package.createdAt ? package.createdAt|date('Y-m-d H:i') : '—' }}</td>
                <td><span class="badge">{{ package.category ? package.category.name : '—' }}</span></td>
                <td>{{ package.business ? package.business.name : '—' }}</td>
                <td class="table-actions">
                    {% if isMysteryBox %}
                        {% if is_granted('ROLE_CONSUMER') %}
                            <form method="post" action="{{ path('app_order_mystery_box', { id: package.business.id }) }}" onsubmit="return confirm('Order a mystery box from {{ package.business.name }}? You cannot cancel this order.');">
                                <button class="btn btn-primary btn-sm" type="submit">Order Mystery Box</button>
                            </form>
                        {% else %}
                            <span class="table-meta">Special package</span>
                        {% endif %}
                    {% else %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_package_view', { id: package.id }) }}">View</a>
                        {% if is_granted('ROLE_BUSINESS') and app.user.business == package.business %}
                            <a class="btn btn-ghost btn-sm" href="{{ path('app_package_edit', { id: package.id }) }}">Edit</a>
                            <a class="btn btn-danger btn-sm" href="{{ path('app_package_delete', { id: package.id }) }}" onclick="return confirm('Delete this package?');">Delete</a>
                        {% endif %}
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">
                    <div class="empty-state">No packages found yet.</div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
