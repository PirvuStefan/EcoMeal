{% extends 'base.html.twig' %}

{% block title %}Package #{{ package.id }} | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Package profile</p>
            <h1 class="page-title">{{ package.description }}</h1>
            <p class="page-subtitle">{{ package.business ? package.business.name : 'Unassigned business' }}</p>
        </div>

        <div class="toolbar">
            {% if is_granted('ROLE_BUSINESS') %}
                <a class="btn btn-primary" href="{{ path('app_package_edit', { id: package.id }) }}">Edit package</a>
            {% endif %}
            {% if is_granted('ROLE_CONSUMER') and package.status == 'available' %}
                <form method="post" action="{{ path('app_order_create_from_package', { id: package.id }) }}">
                    <button class="btn btn-primary" type="submit">Order</button>
                </form>
            {% endif %}
            <a class="btn btn-ghost" href="{{ path('app_package') }}">Back to list</a>
        </div>
    </section>

    <section class="detail-grid">
        <article class="card detail-card detail-card--wide">
            <p class="eyebrow">Details</p>
            <dl class="info-list">
                <div>
                    <dt>ID</dt>
                    <dd>{{ package.id }}</dd>
                </div>
                <div>
                    <dt>Description</dt>
                    <dd>{{ package.description }}</dd>
                </div>
                <div>
                    <dt>Price</dt>
                    <dd>{{ package.price }}</dd>
                </div>
                <div>
                    <dt>Photo</dt>
                    <dd>{{ package.photo }}</dd>
                </div>
                <div>
                    <dt>Created at</dt>
                    <dd>{{ package.createdAt ? package.createdAt|date('Y-m-d H:i:s') : '—' }}</dd>
                </div>
                <div>
                    <dt>Category</dt>
                    <dd>{{ package.category ? package.category.name : '—' }}</dd>
                </div>
                <div>
                    <dt>Status</dt>
                    <dd><span class="badge badge--{{ package.status }}">{{ package.status|capitalize }}</span></dd>
                </div>
            </dl>
        </article>

        <article class="card detail-card detail-card--narrow">
            <p class="eyebrow">Business</p>
            <p class="stat">#{{ package.business ? package.business.id : '—' }}</p>
            <p class="muted">{{ package.business ? package.business.name : 'No business assigned' }}</p>
            {% if is_granted('ROLE_CONSUMER') and package.business %}
                {% if is_favorite %}
                    <form method="post" action="{{ path('app_favorite_remove', { id: package.business.id }) }}">
                        <button class="btn btn-ghost btn-sm" type="submit">Remove from favorites</button>
                    </form>
                {% else %}
                    <form method="post" action="{{ path('app_favorite_add', { id: package.business.id }) }}">
                        <button class="btn btn-ghost btn-sm" type="submit">Add to favorites</button>
                    </form>
                {% endif %}
            {% endif %}
        </article>
    </section>
{% endblock %}
