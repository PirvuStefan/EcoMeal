{% extends 'base.html.twig' %}

{% block title %}New Business | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Business form</p>
            <h1 class="page-title">Create business</h1>
            <p class="page-subtitle">Add a clean, easy-to-find profile for a new partner.</p>
        </div>
    </section>

    <section class="form-card">
        {{ form_start(form, {'attr': {'class': 'app-form'}}) }}
        <div class="form-grid">
            {{ form_row(form.name) }}
            {{ form_row(form.city) }}
            {{ form_row(form.street) }}
            {{ form_row(form.houseNumber) }}
            {{ form_row(form.phoneNumber) }}
            {{ form_row(form.businessType) }}
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" type="submit">Create business</button>
            <a class="btn btn-ghost" href="{{ path('app_business') }}">Back to list</a>
        </div>
        {{ form_end(form) }}
    </section>
{% endblock %}
