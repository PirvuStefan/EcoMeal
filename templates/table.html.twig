<div class="table-shell">
    <table class="data-table">
        <thead>
        <tr>
            <th>Name</th>
            <th>Package</th>
            <th>Price</th>
            <th>Photo</th>
            <th>Created at</th>
            <th>Category</th>
            <th>Business</th>
            <th>Actions</th>
        </tr>
        </thead>
        <tbody>
        {% for package in packages %}
            <tr>
                <td>
                    {{ package.name ? package.name : '—' }}
                </td>
                <td>
                    <a class="table-link" href="{{ path('app_package_view', { id: package.id }) }}">
                        {{ package.description }}
                    </a>
                    <div class="table-meta">ID {{ package.id }}</div>
                </td>
                <td>{{ package.price|number_format(2, '.', ',') }}</td>
                <td>{{ package.photo }}</td>
                <td>{{ package.createdAt ? package.createdAt|date('Y-m-d H:i') : '—' }}</td>
                <td><span class="badge">{{ package.category ? package.category.name : '—' }}</span></td>
                <td>{{ package.business ? package.business.name : '—' }}</td>
                <td class="table-actions">
                    <a class="btn btn-ghost btn-sm" href="{{ path('app_package_view', { id: package.id }) }}">View</a>
                    {% if is_granted('ROLE_BUSINESS') and app.user.business == package.business %}
                        <a class="btn btn-ghost btn-sm" href="{{ path('app_package_edit', { id: package.id }) }}">Edit</a>
                        <a class="btn btn-danger btn-sm" href="{{ path('app_package_delete', { id: package.id }) }}" onclick="return confirm('Delete this package?');">Delete</a>
                    {% endif %}
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="7">
                    <div class="empty-state">No packages found yet.</div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>
