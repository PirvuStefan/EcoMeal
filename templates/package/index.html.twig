{% extends 'base.html.twig' %}

{% block title %}Packages | EcoMeal{% endblock %}

{% block body %}
    <section class="page-head">
        <div>
            <p class="eyebrow">Catalog</p>
            <h1 class="page-title">Packages</h1>
            <p class="page-subtitle">Browse all offers and open a package to review its details.</p>
        </div>

        <div class="toolbar">
            {% if is_granted('ROLE_BUSINESS') %}
                <a class="btn btn-primary" href="{{ path('app_business') }}">Add package via business</a>
            {% endif %}
        </div>
    </section>

    <section class="card">
        <div class="card-header">
            <div>
                <strong>{{ packages|length }}</strong>
                <span class="muted">packages total</span>
            </div>
        </div>

        {{ include('table.html.twig', { packages: packages }) }}
    </section>
{% endblock %}
